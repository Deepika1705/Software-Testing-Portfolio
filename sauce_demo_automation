package testing;

import java.awt.Desktop.Action;
import java.time.Duration;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.interactions.Actions;
import org.testng.Assert;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.Test;

import net.bytebuddy.build.Plugin.Factory.UsingReflection.Priority;

public class LoginTest {
	WebDriver driver;

	@BeforeMethod
	public void setup() {
		try {

			ChromeOptions options = new ChromeOptions();
			options.addArguments("--disable-notifications");
			Map<String, Object> prefs = new HashMap<>();
			prefs.put("credentials_enable_service", false);
			prefs.put("profile.password_manager_enabled", false);
			prefs.put("profile.password_manager_leak_detection", false);
			options.setExperimentalOption("prefs", prefs);

			driver = new ChromeDriver(options);
			driver.navigate().to("https://www.saucedemo.com/");
			driver.manage().window().maximize();
			driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

		} catch (Exception e) {
			throw new RuntimeException("Setup failed - Browser launch or login page elements not found", e);
		}
	}

	@Test(priority = 0)
	public void positiveCase() {
		try {
			login("standard_user", "secret_sauce");
			add_items_to_cart();
			checkout();
			yourinformation();
			finish();
		} catch (Exception e) {
			System.out.println("Test Execution Failed : " + e.getMessage());
		}
	}

	@Test(priority = 1)
	public void negativeCase() {
		try {
			login("locked_out_user", "secret_sauce");

		} catch (Exception e) {
			System.out.println("Test Execution Failed : " + e.getMessage());
		}
	}

	public void login(String username, String password) {
		try {

			WebElement userNametextbox = driver.findElement(By.xpath("//input[@id='user-name']"));
			WebElement passwordtextbox = driver.findElement(By.xpath("//input[@id='password']"));
			WebElement login = driver.findElement(By.xpath("//input[@name='login-button']"));
			userNametextbox.sendKeys(username);
			passwordtextbox.sendKeys(password);
			login.click();
			if (username.equals("locked_out_user")) {
				String actualMessage = driver.findElement(By.xpath("//h3[@data-test='error']")).getText();
				String expectedMessage = "Epic sadface: Sorry, this user has been locked out.";
				Assert.assertEquals(actualMessage, expectedMessage, "Locked user error message validation failed");
				System.out.println("Locked user validation successful");
			} else {
				System.out.println("Logged in successfully");
			}
		} catch (Exception e) {
			throw new RuntimeException("Login failed - Username/password field or login button issue", e);
		}

	}

	public void add_items_to_cart() {
		try {
			WebElement addToCart1 = driver.findElement(By.xpath("//button[@id='add-to-cart-sauce-labs-backpack']"));
			WebElement addToCart2 = driver.findElement(By.xpath("//button[@name='add-to-cart-sauce-labs-bike-light']"));
			WebElement cart = driver.findElement(By.xpath("//a[@data-test='shopping-cart-link']"));
			addToCart1.click();
			addToCart2.click();
			cart.click();
		} catch (Exception e) {
			throw new RuntimeException("Add to cart failed - Product button/cart issue", e);
		}
	}

	public void checkout() {
		try {
			WebElement checkOut = driver.findElement(By.xpath("//button[@name='checkout']"));
			List<WebElement> products = driver.findElements(By.xpath("//div[@class='inventory_item_name']"));
			boolean backPackvisited = false;
			boolean bikelightvisited = false;
			for (WebElement product : products) {
				String productname = product.getText();
				if (productname.equals("Sauce Labs Backpack")) {
					backPackvisited = true;
				}
				if (productname.equals("Sauce Labs Bike Light")) {
					bikelightvisited = true;
				}
			}
			Assert.assertTrue(backPackvisited, "back pack is not found in cart");
			Assert.assertTrue(bikelightvisited, "back pack is not found in cart");
			checkOut.click();
		} catch (Exception e) {
			throw new RuntimeException("Checkout failed - Product validation or checkout button issue", e);
		}
	}

	public void yourinformation() {
		try {

			WebElement firstName = driver.findElement(By.xpath("//input[@id='first-name']"));
			WebElement lastName = driver.findElement(By.xpath("//input[@id='last-name']"));
			WebElement Zipcode = driver.findElement(By.xpath("//input[@id='postal-code']"));
			WebElement Continue = driver.findElement(By.xpath("//input[@id='continue']"));
			firstName.sendKeys("Deepika");
			lastName.sendKeys("J");
			Zipcode.sendKeys("600089");
			Continue.click();
		} catch (Exception e) {
			throw new RuntimeException("User information submission failed", e);
		}

	}

	public void finish() {
		try {
			WebElement Finish = driver.findElement(By.xpath("//button[@name='finish']"));
			Finish.click();
			String actualmessage = driver.findElement(By.xpath("//h2[@class= 'complete-header']")).getText();
			String expectedmessage = "Thank you for your order!";
			Assert.assertEquals(actualmessage, expectedmessage);
			System.out.println("Order Completed Sucessfully");
		} catch (Exception e) {
			throw new RuntimeException("Finish order failed - Success message validation issue", e);
		}

	}

	@AfterMethod
	public void teardown() {
		try {
			driver.quit();
		} catch (Exception e) {
			System.out.println("Browser closing failed : " + e.getMessage());
		}
	}
}
